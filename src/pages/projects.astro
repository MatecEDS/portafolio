</Layout>

<style>

.project-card {
	background: rgba(14,14,14,0.66);
	border: 1px solid rgba(0,255,102,0.15);
	padding: 2.5rem;
	border-radius: 1rem;
	transition: all 0.4s ease;
}

.project-card:hover {
	border-color: rgba(0,255,102,0.6);
	transform: translateY(-6px);
	box-shadow: 0 0 40px rgba(0,255,102,0.08);
}

.project-header {
	display: flex;
	align-items: center;
	gap: 12px;
	margin-bottom: 20px;
}

.project-header h2 {
	color: #00FF66;
	font-size: 1.4rem;
	font-family: 'onest', sans-serif;
}

.project-card p {
	color: #9ca3af;
	margin-bottom: 20px;
	line-height: 1.6;
}

.tech {
	display: flex;
	flex-wrap: wrap;
	gap: 10px;
}

.tech span {
	font-size: 0.75rem;
	padding: 6px 12px;
	border: 1px solid rgba(0,255,102,0.3);
	color: #00FF66;
	border-radius: 999px;
	letter-spacing: 0.08em;
	text-transform: uppercase;
}

</style>

<script>
  const items = document.querySelectorAll('.principio');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const element = entry.target;
        const delay = Array.from(items).indexOf(element) * 150;
        setTimeout(() => {
          element.classList.add('visible');
        }, delay);
        observer.unobserve(element);
      }
    });
  }, {
    threshold: 0.2
  });

  items.forEach(item => observer.observe(item));
</script>

<script>
  const items = document.querySelectorAll('.group');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const element = entry.target;
        const delay = Array.from(items).indexOf(element) * 150;
        setTimeout(() => {
          element.classList.add('visible');
        }, delay);
        observer.unobserve(element);
      }
    });
  }, {
    threshold: 0.2
  });

  items.forEach(item => observer.observe(item));
</script>

<script>
  function generateBlob() {
    const points = 8;
    const radius = 250;
    const center = 300;

    let path = "";

    for (let i = 0; i < points; i++) {
      const angle = (Math.PI * 2 * i) / points;
      const randomRadius = radius + (Math.random() * 120 - 60);
      const x = center + randomRadius * Math.cos(angle);
      const y = center + randomRadius * Math.sin(angle);

      path += `${i === 0 ? "M" : "L"} ${x} ${y} `;
    }

    path += "Z";
    return path;
  }

  const container = document.getElementById("bg-shape");

  const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
  svg.setAttribute("viewBox", "0 0 600 600");
  svg.classList.add("w-[800px]", "h-[800px]", "opacity-20", "blur-3xl");

  const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
  path.setAttribute("d", generateBlob());
  path.setAttribute("fill", "#00FF66");

  svg.appendChild(path);
  container!.appendChild(svg);
</script>
