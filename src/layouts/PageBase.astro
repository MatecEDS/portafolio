---
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';
import '@fontsource/orbitron/700.css';
import '@fontsource/bebas-neue';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "RPTR Tech - Tecnología de Precisión y Vanguardia. Ingeniería y desarrollo de sistemas de alto rendimiento." } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="RPTR Tech" />
    <meta name="theme-color" content="#0B0B0B" />
    
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    
    <title>{title} | RPTR Tech</title>
  </head>

  <body>
    <div id="bg-shape" 
      class="fixed inset-0 flex items-center justify-center pointer-events-none -z-30">
    </div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --negro-base: #0B0B0B;
    --superficie: #141414;
    --verde-principal: #00FF66;
    --verde-profundo: #00C853;
    --gris-tecnico: #1F1F1F;
    --blanco-tecnico: #EDEDED;
  }

  html {
    font-family: 'Bebas Neue', sans-serif;
    background-color: var(--negro-base);
    color: var(--blanco-tecnico);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
  }

  header {
    width: 100%;
    backdrop-filter: blur(8px);
    background-color: rgba(11, 11, 11, 0.6);
    border-bottom: 1px solid rgba(0, 255, 102, 0.1);
    z-index: 1000;
  }

  h1, h2, h3, h4 {
    color: var(--verde-principal);
    font-weight: 700;
    letter-spacing: 1px;
  }

  p, li {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 300;
    color: var(--blanco-tecnico);
  }
</style>